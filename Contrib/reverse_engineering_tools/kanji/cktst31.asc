1000 DEFINT A-Z:A=0:B=1:REM This version is intended for compilation by MSX-BACON. Otherwise it will run very slowly, provided it can even fit in BASIC RAM.
1010 GOSUB 1020:GOTO 2010
1020 DIM L(7),K(7),T(7):BEEP:SCREEN 2:COLOR 15,1,1:CLS:F=0:E=&H2000
1030 T$="Kanji I/O Tests":V$="v3.1":N$=" Please share screen pic+model"+CHR$(&H16)+"press a key ":Q=7:W=0:C=PEEK(&H4)+&H100*PEEK(&H5)
1040 Z=0:D=0:Y=0:S$=" "+T$+" 1/9: Kanji Detection "+V$+" ":W=&HFF:GOSUB 1750:W=0:D=0
1050 ' 6x8 / 8x8 BIOS
1060 FOR Y=1 TO 2:S$="":IF Y=1 THEN RESTORE 1810:ELSE RESTORE 1840
1070 READ K$:IF K$="" THEN GOTO 1080:ELSE K$="&H"+K$:S$=S$+CHR$(VAL(K$)):GOTO1070
1080 D=0:GOSUB 1750:D=0:NEXT Y
1090 ' 8x16 / 16x16 Kanji
1100 Z=32:RESTORE 1860
1110 READ K$:IF K$=""THEN GOTO 1200ELSE L=0:K=VAL("&H"+K$):IF K<&H100 THEN GOTO 1160:ELSE GOSUB 1690
1120 IF Z MOD 32=31 THEN Z=Z+1
1130 OUT &HD9+2*L,K:OUT &HD8+2*L,T
1140 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=Z MOD 32 TO 1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9+2*L):GOSUB 1760:NEXT J:NEXT X:NEXT Y
1150 Z=Z+2:GOTO 1110
1160 IF K>=&H80 THEN K=K+8*96-&H20
1170 OUT &HD9,(K-&H20)\&H40:OUT &HD8,(K-&H20)MOD&H40
1180 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=Z MOD 32 TO 1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9+2*L):ON 1-(X=(Z MOD 32)) GOSUB 1780,1760:NEXT J:NEXT X:NEXT Y
1190 Z=Z+1:GOTO 1110
1200 ' v1.0
1210 OUT &HD9,&H2:OUT &HD8,&H3C:OUT &HDB,&H2:OUT &HDA,&H3A
1220 FOR L=1 TO 0 STEP -1:FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=2*L+Z MOD 32 TO 2*L+1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9+2*L):GOSUB 1760:NEXT J:NEXT X:NEXT Y:NEXT L
1230 Z=Z+4
1240 GOSUB 1710:IF A=1 THEN GOTO 1660
1250 CLS:Z=0:D=0:Y=0:S$=" "+T$+" 2/9: Interleaving A  "+V$+" ":W=&HFF:GOSUB 1750:W=0:Z=0:D=0
1260 RESTORE 1950:FOR N=0 TO 7:READ K$:L=0:K=VAL("&H"+K$):GOSUB 1690:L(N)=L:K(N)=K:T(N)=T:NEXT N
1270 FOR N=2 TO 7:IF L(0)<>0 OR L(N)<>L(N-2)OR L(N)=L(N-1)OR((K(N)<>K(N-2))AND(T(N)<>T(N-2)))THEN SCREEN 0:PRINT"Data does not conform":A=1:GOTO 1660:ELSE NEXT N
1280 'plan 1/2/3/4
1290 FOR R=0 TO 1:GOSUB 1800
1300 FOR L=0 TO 1:FOR N=0 TO 7:K=K(N):T=T(N):IF L(N)<>L THEN GOTO 1350
1310 IF (R MOD 2=1) AND (N<2 OR T((8+N-2)MOD 8)<>T) THEN OUT &HD8+2*L,T
1320 IF N<2 OR K((8+N-2)MOD 8)<>K THEN OUT &HD9+2*L,K
1330 IF (R MOD 2=0) AND (N<2 OR T((8+N-2)MOD 8)<>T) THEN OUT &HD8+2*L,T
1340 FOR Y=1+2*((Z+2*N)\32) TO 4+2*((Z+2*N)\32):GOSUB 1680:NEXT Y
1350 NEXT N:NEXT L:Z=Z+16:IF(Z MOD 32)<16 THEN Z=Z+32
1360 NEXT R
1370 'plan 5/6/7/8
1380 FOR R=0 TO 3:GOSUB 1800
1390 FOR N2=0 TO 7 STEP 2:FOR P=0 TO 5:L=(-(((P>=1)AND(P<=2))OR(P=4)))XOR(R MOD 2):N=N2+L:K=K(N):T=T(N)
1400 IF ((R\2)MOD 2=1) AND (P<2 AND (N<2 OR T((8+N-2)MOD 8)<>T)) THEN OUT &HD8+2*L,T
1410 IF P<2 AND (N<2 OR K((8+N-2)MOD 8)<>K) THEN OUT &HD9+2*L,K
1420 IF ((R\2)MOD 2=0) AND (P<2 AND (N<2 OR T((8+N-2)MOD 8)<>T)) THEN OUT &HD8+2*L,T
1430 IF P>=2 THEN FOR Y=1-2*(P>=4)+2*((Z+2*N)\32) TO 2-2*(P>=4)+2*((Z+2*N)\32):GOSUB 1680:NEXT Y
1440 NEXT P:NEXT N2:Z=Z+16:IF(Z MOD 32)<16 THEN Z=Z+32
1450 NEXT R
1460 'plan 9/10/11/12
1470 FOR R=0 TO 3:GOSUB 1800
1480 FOR N2=0 TO 7 STEP 2:FOR P=0 TO 4+2*2*32-1:L=(P MOD 2)XOR(-(P<4))XOR(R MOD 2):N=N2+L:K=K(N):T=T(N)
1490 IF ((R\2)MOD 2=1) AND (P>=2 AND P<4 AND (N<2 OR T((8+N-2)MOD 8)<>T)) THEN OUT &HD8+2*L,T
1500 IF P<2 AND (N<2 OR K((8+N-2)MOD 8)<>K) THEN OUT &HD9+2*L,K
1510 IF ((R\2)MOD 2=0) AND (P>=2 AND P<4 AND (N<2 OR T((8+N-2)MOD 8)<>T)) THEN OUT &HD8+2*L,T
1520 IF P>=4 THEN Y=1+((P-4)\32) MOD 4+2*((Z+2*N)\32):X=((P-4)\16) MOD 2+(Z+2*N) MOD 32:J=((P-4)\2) MOD 8:G=INP(&HD9+2*L):GOSUB 1760
1530 NEXT P:NEXT N2:Z=Z+16:IF(Z MOD 32)<16 THEN Z=Z+32
1540 NEXT R
1550 GOSUB 1710:IF A=1 THEN GOTO 1660
1560 CLS:Z=0:D=0:Y=0:S$=" "+T$+" 3/9: Interleaving B  "+V$+" ":W=&HFF:GOSUB 1750:W=0:Z=0:D=0
1570 'plan 13/14/15/16
1580 FOR R=0 TO 3:GOSUB 1800
1590 FOR N2=0 TO 7 STEP 2:FOR P=0 TO 4+4-1:L=(P MOD 2)XOR(-(P<4))XOR(R MOD 2):N=N2+L:K=K(N):T=T(N)
1600 IF (P<2 AND R<2) OR (P>=2 AND P<4 AND R>=2 AND R<4) AND (N<2 OR K((8+N-2)MOD 8)<>K) THEN OUT &HD9+2*L,K
1610 IF (P<2 AND R>=2 AND R<4) OR (P>=2 AND P<4 AND R<2) AND (N<2 OR T((8+N-2)MOD 8)<>T) THEN OUT &HD8+2*L,T
1620 IF P>=4 THEN FOR Y=1-2*(P>=6)+2*((Z+2*N)\32) TO 2-2*(P>=6)+2*((Z+2*N)\32):GOSUB 1680:NEXT Y
1630 NEXT P:NEXT N2:Z=Z+16:IF(Z MOD 32)<16 THEN Z=Z+32
1640 NEXT R
1650 GOSUB 1710:IF A=1 THEN GOTO 1660
1660 IF A=1 THEN SCREEN 0:PRINT"Abnormal exit"
1670 IF B<>2 THEN RETURN:ELSE GOTO 2000
1680 FOR X=(Z+2*N) MOD 32 TO 1+(Z+2*N) MOD 32:FOR J=0 TO 7:G=INP(&HD9+2*L):GOSUB 1760:NEXT J:NEXT X:RETURN
1690 T=(K MOD &H100)-&H20:K=K\&H100-&H20:IF K>=&H30 THEN K=K-&H30:L=1:ELSE IF K>&H9 AND K<&H30 THEN K=K-&H6:T=T+&H40
1700 K=K*96+T:T=K MOD&H40:K=K\&H40:RETURN
1710 Y=23:S$=N$:W=&HFF:GOSUB 1750:W=0
1720 I$=INKEY$:IF I$=CHR$(&H3) OR I$=CHR$(&H1B) THEN SCREEN 0:A=1:GOTO 1740:ELSE:IF I$<>"" THEN GOTO 1720:ELSE BEEP
1730 I$=INKEY$:IF I$="" THEN GOTO 1730:ELSE IF I$=CHR$(&H3) OR I$=CHR$(&H1B) THEN SCREEN 0:A=1:GOTO 1740
1740 RETURN
1750 D=0:FOR X=0 TO LEN(S$)-1:V=ASC(MID$(S$,1+X,1)):Q=7+2*(V>=&H20 AND V<&H7F):FOR J=0 TO 7:G=PEEK(C+8*V+J):GOSUB 1760:NEXT J:D=D+Q-7:NEXT X:Q=7:RETURN
1760 GG=G XOR W:IF GG=0 THEN RETURN:ELSE XX=8*X+D:IF GG=&HFF THEN YY=8*Y+J:LINE(XX,YY)-(XX+Q,YY),15:RETURN:ELSE IF Q=7 AND D MOD 8=0 THEN GOTO 1790:ELSE M=&H80:YY=8*Y+J:FOR I=0 TO Q:IF (GG\M)MOD 2<>0 THEN PSET(XX+I,YY),15
1770 M=M\2:NEXT I:RETURN
1780 RETURN
1790 O=Y*&H100+XX+J:VPOKE E+O,15*&H10:VPOKE F+O,GG:RETURN
1800 IF ((Z+15)MOD 32)<15 THEN Z=((Z\32)+2)*32:RETURN:ELSE RETURN
1810 DATA 42,49,4F,53,3A,01,02,03,04,05,06,07,08,09,0A,0B,0C,0D,0E,0F,1D,1E,1F
1820 DATA 20,EB,F7,96,DE,E5,20,B6,C0,B6,C5
1830 DATA:'End of DATA
1840 DATA 20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,20,FF,52,6F,6D,61,6A,69,FF,83,82,81,80
1850 DATA:'End of DATA
1860 DATA 4C,76,31,20,3441,3B7A,2127,376E,3250,3F65,4C5A,3662,455A,467C,472F,315F,3B7E,4A2C,4943,4934,4069,4B7C,4267,4366,3E2E
1870 DATA 20,2452,2469,242C,244A,20,252B,253F,252B,254A,2352,236F,236D,2361,236A,2369,20,B6,C0,B6,C5,20,52,6F,6D,61,6A,69
1880 DATA 2221,217A,2227,2225
1890 DATA 2347,2372,2365,2365,2374,2369,236E,2367,2373,212A,2121,2350,2355,2354,234B,2341,234E,234A,2349
1900 DATA 2148,3441,3B7A,244F,3A47,3962,2447,2439,2123,2149
1910 DATA 297B,297C,297A
1920 DATA 4C,76,32,20,3441,3B7A,2127,5579,5378,5579,5239,5378,524C,5144,7775,776F,7773,7771
1930 DATA 534C,5376,5332,5F21,665A,5127,5121,534D,5349,5353,5344,5352,5341,5357,534E,512A
1940 DATA 4C,76,31,2F,4C,76,32,3A,217C,517A,2121,2121:'v1.0
1950 DATA 2363,5239,236F,5241,264F,5161,264A,5144:'v2.0
1960 DATA 4C,76,32,E3,4C,76,31,3A,517C,217A,2121,2121
1970 DATA 5363,2239,536F,2241,564F,2161,564A,2144
1980 DATA 20,2277,50,72,65,76,69,6F,75,73,20,74,65,73,74,2278,2121,2327,2121,20
1990 DATA:'End of DATA
2000 '
2010 IF A=0 THEN GOTO 2030
2020 GOTO 3250
2030 A=0:B=1:GOSUB 2040:GOTO 2600
2040 CLS
2050 Q=7:W=0
2060 Z=0:D=0:Y=0:S$=" "+T$+" 4/9: Upper Bit Flips "+V$+" ":W=&HFF:GOSUB 1750:W=0:D=0
2070 ' 8x16 / 16x16 Kanji only cycling upper address bits
2080 ZZ=&HC0:ZY=&HC0:Z=0:RESTORE 1860
2090 READ K$:IF K$=""THEN GOTO 2180ELSE ZZ=(&H40+ZZ)MOD&H100:ZY=(ZY-&H40*(ZZ=0))MOD&H100:L=0:K=VAL("&H"+K$):IF K<&H100 THEN GOTO 2140:ELSE GOSUB 1690
2100 IF Z MOD 32=31 THEN Z=Z+1
2110 OUT &HD9+2*L,K+ZY:OUT &HD8+2*L,T+ZZ
2120 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=Z MOD 32 TO 1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9+2*L):GOSUB 1760:NEXT J:NEXT X:NEXT Y
2130 Z=Z+2:GOTO 2090
2140 IF K>=&H80 THEN K=K+8*96-&H20
2150 OUT &HD9,(K-&H20)\&H40+ZY:OUT &HD8,(K-&H20)MOD&H40+ZZ
2160 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=Z MOD 32 TO 1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9+2*L):ON 1-(X=(Z MOD 32)) GOSUB 1780,1760:NEXT J:NEXT X:NEXT Y
2170 Z=Z+1:GOTO 2090
2180 ' v1.0 only varying upper address bits
2190 OUT &HD9,&HC2:OUT &HD8,&HBC:OUT &HDB,&H42:OUT &HDA,&H3A
2200 FOR L=1 TO 0 STEP -1:FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=2*L+Z MOD 32 TO 2*L+1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9+2*L):GOSUB 1760:NEXT J:NEXT X:NEXT Y:NEXT L
2210 Z=Z+4
2220 GOSUB 1710:IF A=1 THEN GOTO 2570
2230 CLS:Z=0:D=0:Y=0:S$=" "+T$+" 5/9: Lower Readbacks "+V$+" ":W=&HFF:GOSUB 1750:W=0:Z=0:D=0
2240 ' 8x16 / 16x16 Kanji only lower-port readbacks
2250 Z=0:RESTORE 1860
2260 READ K$:IF K$=""THEN GOTO 2350ELSE L=0:K=VAL("&H"+K$):IF K<&H100 THEN GOTO 2310:ELSE GOSUB 1690
2270 IF Z MOD 32=31 THEN Z=Z+1
2280 OUT &HD9+2*L,K:OUT &HD8+2*L,T
2290 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=Z MOD 32 TO 1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD8+2*L):GOSUB 1760:NEXT J:NEXT X:NEXT Y
2300 Z=Z+2:GOTO 2260
2310 IF K>=&H80 THEN K=K+8*96-&H20
2320 OUT &HD9,(K-&H20)\&H40:OUT &HD8,(K-&H20)MOD&H40
2330 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=Z MOD 32 TO 1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD8+2*L):ON 1-(X=(Z MOD 32)) GOSUB 1780,1760:NEXT J:NEXT X:NEXT Y
2340 Z=Z+1:GOTO 2260
2350 ' v1.0 only lower-port readbacks
2360 OUT &HD9,&H2:OUT &HD8,&H3C:OUT &HDB,&H2:OUT &HDA,&H3A
2370 FOR L=1 TO 0 STEP -1:FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=2*L+Z MOD 32 TO 2*L+1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD8+2*L):GOSUB 1760:NEXT J:NEXT X:NEXT Y:NEXT L
2380 Z=Z+4
2390 GOSUB 1710:IF A=1 THEN GOTO 2570
2400 CLS:Z=0:D=0:Y=0:S$=" "+T$+" 6/9: Read Port Flips "+V$+" ":W=&HFF:GOSUB 1750:W=0:Z=0:D=0
2410 ' 8x16 / 16x16 Kanji only read-port address LSB flips
2420 Z=0:RESTORE 1860
2430 READ K$:IF K$=""THEN GOTO 2520ELSE L=0:K=VAL("&H"+K$):IF K<&H100 THEN GOTO 2480:ELSE GOSUB 1690
2440 IF Z MOD 32=31 THEN Z=Z+1
2450 OUT &HD9+2*L,K:OUT &HD8+2*L,T
2460 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=Z MOD 32 TO 1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9-(J MOD 2)+2*L):GOSUB 1760:NEXT J:NEXT X:NEXT Y
2470 Z=Z+2:GOTO 2430
2480 IF K>=&H80 THEN K=K+8*96-&H20
2490 OUT &HD9,(K-&H20)\&H40:OUT &HD8,(K-&H20)MOD&H40
2500 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=Z MOD 32 TO 1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9-(J MOD 2)+2*L):ON 1-(X=(Z MOD 32)) GOSUB 1780,1760:NEXT J:NEXT X:NEXT Y
2510 Z=Z+1:GOTO 2430
2520 ' v1.0 only read-port address LSB flips
2530 OUT &HD9,&H2:OUT &HD8,&H3C:OUT &HDB,&H2:OUT &HDA,&H3A
2540 FOR L=1 TO 0 STEP -1:FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR X=2*L+Z MOD 32 TO 2*L+1+Z MOD 32:FOR J=0 TO 7:G=INP(&HD9-(J MOD 2)+2*L):GOSUB 1760:NEXT J:NEXT X:NEXT Y:NEXT L
2550 Z=Z+4
2560 GOSUB 1710
2570 IF A=1 THEN SCREEN 0:PRINT"Abnormal exit"
2580 IF B<>2 THEN RETURN:ELSE GOTO 2590
2590 '
2600 IF A=0 THEN GOTO 2620
2610 GOTO 3250
2620 A=0:B=1:GOSUB 2630:GOTO 3240
2630 CLS
2640 T$="Hanja I/O Tests":Q=7:W=0
2650 Z=0:D=0:Y=0:S$=" "+T$+" 7/9: Hanja Detection "+V$+" ":W=&HFF:GOSUB 1750:W=0:D=0
2660 ' 6x8 / 8x8 BIOS font
2670 FOR Y=1 TO 2:S$="":IF Y=1 THEN RESTORE 3080:ELSE RESTORE 3100
2680 READ K$:IF K$="" THEN GOTO 2690:ELSE K$="&H"+K$:S$=S$+CHR$(VAL(K$)):GOTO2680
2690 D=0:GOSUB 1750:D=0:NEXT Y
2700 ' 16x16 Hangul+Hanja + 8x8 BIOS font scan-doubled to 8x16
2710 Z=32:RESTORE 3120
2720 READ K$:IF K$=""THEN GOTO 2790ELSE K=VAL("&H"+K$):IFK<&H100 THEN GOTO 2770:ELSE GOSUB 3050
2730 IF Z MOD 32=31 THEN Z=Z+1
2740 OUT &HD9,K:OUT &HD8,T
2750 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR J=0 TO 7:FOR X=Z MOD 32 TO 1+Z MOD 32:G=INP(&HD9):GOSUB 1760:NEXT X:NEXT J:NEXT Y
2760 Z=Z+2:GOTO 2720
2770 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):X=Z MOD 32:FOR J=0 TO 7:G=PEEK(C+8*K+4*((Y-1)MOD 2)+(J\2)):GOSUB 1760:NEXT J:NEXT Y
2780 Z=Z+1:GOTO 2720
2790 GOSUB 1710:IF A=1 THEN GOTO 3020
2800 CLS:Z=0:D=0:Y=0:S$=" "+T$+" 8/9: Upper Bit Flips "+V$+" ":W=&HFF:GOSUB 1750:W=0:Z=0:D=0
2810 ' 16x16 Hangul+Hanja (upper bits flipped) + 8x8 BIOS font scan-doubled to 8x16
2820 ZZ=&HC0:ZY=&H80:Z=0:RESTORE 3120
2830 READ K$:IF K$=""THEN GOTO 2900ELSE ZZ=(&H40+ZZ)MOD&H100:ZY=(ZY-&H80*(ZZ=0))MOD&H100:K=VAL("&H"+K$):IFK<&H100 THEN GOTO 2880:ELSE GOSUB 3050
2840 IF Z MOD 32=31 THEN Z=Z+1
2850 OUT &HD9,K+ZY:OUT &HD8,T+ZZ
2860 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR J=0 TO 7:FOR X=Z MOD 32 TO 1+Z MOD 32:G=INP(&HD9):GOSUB 1760:NEXT X:NEXT J:NEXT Y
2870 Z=Z+2:GOTO 2830
2880 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):X=Z MOD 32:FOR J=0 TO 7:G=PEEK(C+8*K+4*((Y-1)MOD 2)+(J\2)):GOSUB 1760:NEXT J:NEXT Y
2890 Z=Z+1:GOTO 2830
2900 GOSUB 1710:IF A=1 THEN GOTO 3020
2910 CLS:Z=0:D=0:Y=0:S$=" "+T$+" 9/9: Port Rotations  "+V$+" ":W=&HFF:GOSUB 1750:W=0:Z=0:D=0
2920 ' 16x16 Hangul+Hanja (rotating ports) + 8x8 BIOS font scan-doubled to 8x16
2930 L=1:ZZ=1:Z=0:RESTORE 3120
2940 READ K$:IF K$=""THEN GOTO 3010ELSE ZZ=1-ZZ:L=(L-(ZZ=0))MOD 2:K=VAL("&H"+K$):IFK<&H100 THEN GOTO 2990:ELSE GOSUB 3050
2950 IF Z MOD 32=31 THEN Z=Z+1
2960 OUT &HD9+2*L,K:OUT &HD8+2*L,T
2970 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):FOR J=0 TO 7:FOR X=Z MOD 32 TO 1+Z MOD 32:G=INP(&HD9+2*L-ZZ):GOSUB 1760:NEXT X:NEXT J:NEXT Y
2980 Z=Z+2:GOTO 2940
2990 FOR Y=1+2*(Z\32) TO 2+2*(Z\32):X=Z MOD 32:FOR J=0 TO 7:G=PEEK(C+8*K+4*((Y-1)MOD 2)+(J\2)):GOSUB 1760:NEXT J:NEXT Y
3000 Z=Z+1:GOTO 2940
3010 GOSUB 1710:IF A=1 THEN GOTO 3020
3020 IF A=1 THEN SCREEN 0:PRINT"Abnormal exit"
3030 IF B<>2 THEN RETURN:ELSE GOTO 3230
3040 FOR X=(Z+2*N) MOD 32 TO 1+(Z+2*N) MOD 32:FOR J=0 TO 7:G=INP(&HD9+2*L):GOSUB 1760:NEXT J:NEXT X:RETURN
3050 T=(K MOD &H100)-&H21:K=K\&H100-&H21
3060 K=K*94+T:T=K MOD&H40:K=K\&H40:RETURN
3070 IF ((Z+15)MOD 32)<15 THEN Z=((Z\32)+2)*32:RETURN:ELSE RETURN
